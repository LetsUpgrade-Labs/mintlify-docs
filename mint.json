    {
      "group": "Assets",
      "pages": [
        "POST /api/upload-image",
        "POST /api/parse-document"
      ]
    },
    {
      "group": "Admin",
      "pages": [
        "GET /api/admin/stats",
        "GET /api/admin/users",
        "PATCH /api/admin/users",
        "GET /api/admin/api-keys",
        "POST /api/admin/api-keys",
        "DELETE /api/admin/api-keys"
      ]
    }
  ],
  "footerSocials": {
    "website": "https://thelisa.ai"
